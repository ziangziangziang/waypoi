{
  "name": "waypoi",
  "version": "0.7.1-beta.2",
  "description": "Local OpenAI-compatible AI gateway with intelligent routing, failover, MCP tools, and a built-in playground UI",
  "license": "MIT",
  "main": "dist/src/index.js",
  "bin": {
    "waypoi": "dist/cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ziangziangziang/waypoi.git"
  },
  "homepage": "https://github.com/ziangziangziang/waypoi#readme",
  "bugs": {
    "url": "https://github.com/ziangziangziang/waypoi/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "proxy",
    "openai",
    "mcp",
    "local-ai",
    "gateway",
    "playground"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "concurrently -n server,ui -c blue,green \"tsx watch src/index.ts\" \"npm run dev --prefix ui\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:all": "concurrently -n server,ui -c blue,green \"tsx watch src/index.ts\" \"npm run dev --prefix ui\"",
    "build": "tsc -p tsconfig.json && cd ui && npm run build",
    "build:ui": "cd ui && npm run build",
    "build:all": "npm run build",
    "start": "node dist/src/index.js",
    "cli": "tsx cli/index.ts",
    "manual-test": "bash scripts/manual-test.sh",
    "test": "npx tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^12.1.0",
    "fastify": "^5.8.4",
    "sharp": "^0.33.5",
    "undici": "^6.19.8",
    "yaml": "^2.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "concurrently": "^9.1.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
